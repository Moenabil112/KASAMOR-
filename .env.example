# =============================================================================
# KASAMOR Platform — Environment Configuration (example)
# Copy to .env and adjust. The MVP runs locally WITHOUT any of these set.
# =============================================================================

# --- Core paths ---
KASAMOR_DATA_DIR=./data
KASAMOR_BASE_KNOWLEDGE_DIR=./data/base-knowledge
KASAMOR_EXTRACTED_DIR=./data/extracted-knowledge
KASAMOR_OUTPUTS_DIR=./data/outputs

# --- API service ---
KASAMOR_API_HOST=0.0.0.0
KASAMOR_API_PORT=8000

# --- Frontend apps ---
# Public interface and internal console read this to reach the API.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# --- AI providers (OPTIONAL) ---
# KASAMOR is provider-agnostic. Leave blank to use deterministic MOCK agents.
# Set a provider + key only when wiring real models in a later sprint.
KASAMOR_AGENT_MODE=mock            # mock | live
KASAMOR_AI_PROVIDER=               # e.g. anthropic | openai | local
KASAMOR_AI_API_KEY=                # never commit a real key
KASAMOR_AI_MODEL=                  # e.g. claude-sonnet-4-6

# --- Vector store placeholders (NOT required for MVP) ---
# The MVP retrieves from local JSONL. These are reserved for a later sprint.
KASAMOR_VECTOR_BACKEND=jsonl       # jsonl | pgvector | qdrant
PGVECTOR_DSN=                      # postgresql://user:pass@localhost:5432/kasamor
QDRANT_URL=

# --- PostGIS placeholder (NOT required for MVP) ---
POSTGIS_DSN=
